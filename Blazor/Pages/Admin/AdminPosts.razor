@page "/admin/posts"
@page "/admin/posts/{page:int}"

@using Mapper.DTO
<AdminLayout>
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-4">
        @if (PostsData == null)
        {
            <div class="d-flex justify-center my-16">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <MudTable Items="@PostsData.Posts" Hover="true" Elevation="1" Class="mb-8">
                <ToolBarContent>
                    <MudText Typo="Typo.h6" Class="fw-bold">文章管理</MudText>
                    <MudSpacer />
                    @* 状态切换按钮组 *@
                    <MudToggleGroup T="int" Value="@_isDeletedFilter" ValueChanged="OnFilterChanged"
                                    SelectionMode="SelectionMode.SingleSelection" Color="Color.Default" Variant="Variant.Outlined" Class="mr-4">
                        <MudToggleItem Value="0" Text="正常" />
                        <MudToggleItem Value="1" Text="已删除" />
                    </MudToggleGroup>

                    <MudButton Variant="Variant.Outlined"
                               StartIcon="@Icons.Material.Outlined.Add"
                               OnClick="@(() => Utils.NavigateTo($"/admin/postmanager"))">
                        新增
                    </MudButton>
                </ToolBarContent>
                <HeaderContent>
                    <MudTh>ID</MudTh>
                    <MudTh>标题</MudTh>
                    <MudTh>发布时间</MudTh>
                    <MudTh Style="text-align:right">操作</MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd DataLabel="ID">@context.Id</MudTd>
                    <MudTd DataLabel="标题">
                        <MudLink Href="@($"admin/post/{context.Id}")"
                                 Target="_blank"
                                 Underline="Underline.Hover"
                                 Color="Color.Default">
                            <span style="@(_isDeletedFilter == 1 ? "text-decoration: line-through;" : "")">
                                @context.Title
                            </span>
                        </MudLink>
                    </MudTd>
                    <MudTd DataLabel="发布时间">@context.CreationTime.ToString("yyyy-MM-dd HH:mm")</MudTd>
                    <MudTd DataLabel="操作" Style="text-align:right">
                        <MudIconButton Icon="@Icons.Material.Outlined.Edit" Title="编辑"
                                       OnClick="@(() => Utils.NavigateTo($"/admin/postmanager/{context.Id}"))" />
                        @if (_isDeletedFilter == 0)
                        {
                            <MudIconButton Icon="@Icons.Material.Outlined.Delete" Title="删除"
                                           OnClick="@(() => OpenDeleteDialog(context.Id))" />
                        }
                        else
                        {
                            <MudIconButton Icon="@Icons.Material.Outlined.Restore" Title="恢复文章"
                                           OnClick="@(() => ExecuteRestore(context.Id))" />
                        }
                    </MudTd>
                </RowTemplate>
            </MudTable>

            @if (TotalPage > 1)
            {
                <div class="d-flex justify-center">
                    <MudPagination Count="@TotalPage"
                                   Selected="@(page ?? 1)"
                                   SelectedChanged="OnPageChanged"
                                   ShowFirstButton="true"
                                   ShowLastButton="true"
                                   Variant="Variant.Outlined"
                                   Color="Color.Primary" />
                </div>
            }
        }
    </MudContainer>
</AdminLayout>