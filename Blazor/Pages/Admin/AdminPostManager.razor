@page "/admin/postmanager/{Id:int}"
@page "/admin/postmanager"

<AdminLayout>
    <MudContainer MaxWidth="MaxWidth.ExtraLarge" Class="mt-4 mb-8">

        @* 顶部工具栏 *@
        <MudCard Outlined="true" Class="pa-2 mb-4">
            <MudCardContent>
                <MudGrid>
                    @* 标题输入框 - 占据整行 *@
                    <MudItem xs="12">
                        <MudTextField @bind-Value="PostTitle"
                                      Label="Title"
                                      Placeholder="请输入标题..."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense" />
                    </MudItem>

                    @* 标签选择 (多选) *@
                    <MudItem xs="12">
                        <div class="d-flex align-center flex-wrap gap-2">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold mr-2" Style="width: 80px;">Tags:</MudText>
                            <MudChipSet T="int"
                                        SelectedValues="TagsSelected"
                                        SelectedValuesChanged="OnTagsChanged"
                                        SelectionMode="SelectionMode.MultiSelection">
                                @foreach (var tag in AllTags)
                                {
                                    @* Value 绑定 ID，这样 TagsSelected 拿到的就是 ID 列表 *@
                                    <MudChip Value="@tag.Id" Text="@tag.TagName" Color="Color.Primary" Variant="Variant.Outlined" />
                                }
                                <MudChip Icon="@Icons.Material.Outlined.Add" OnClick="OpenAddTagDialog" Color="Color.Primary" Variant="Variant.Text">新增标签</MudChip>
                            </MudChipSet>
                        </div>
                    </MudItem>

                    @* 分类选择 (单选) *@
                    <MudItem xs="12">
                        <div class="d-flex align-center flex-wrap gap-2">
                            <MudText Typo="Typo.subtitle2" Class="fw-bold mr-2" Style="width: 80px;">Categories:</MudText>
                            <MudChipSet T="int"
                                        SelectedValue="PostCategory"
                                        SelectedValueChanged="OnCategoryChanged"
                                        SelectionMode="SelectionMode.ToggleSelection">
                                @foreach (var cat in AllCategories)
                                {
                                    <MudChip Value="@cat.Id" Text="@cat.CategoryName" Color="Color.Secondary" Variant="Variant.Outlined" />
                                }
                                <MudChip Icon="@Icons.Material.Outlined.Add" OnClick="OpenAddCategoryDialog" Color="Color.Secondary" Variant="Variant.Text">新增分类</MudChip>
                            </MudChipSet>
                        </div>
                    </MudItem>
                </MudGrid>
            </MudCardContent>

            @* 底部操作按钮 *@
            <MudCardActions>
                <MudButton Color="Color.Primary"
                           Variant="Variant.Outlined"
                           OnClick="OnSubmit"
                           Disabled="@IsProcessing"
                           StartIcon="@Icons.Material.Filled.Save">
                    提交文章
                </MudButton>
            </MudCardActions>
        </MudCard>

        <MudGrid Style="min-height: 70vh;">
            @* 左侧：编辑器 *@
            <MudItem xs="6" Class="d-flex">
                <MudTextField T="string" @bind-Value="InputText"
                              Immediate="true"
                              DebounceInterval="800"
                              Variant="Variant.Outlined" 
                              Lines="40"
                              MaxLines="80"
                              Placeholder="从此开始"
                              Sizing="InputSizing.Auto" />
            </MudItem>

            @* 右侧：预览区 *@
            <MudItem xs="6" Class="d-flex flex-column">
                <MudPaper Outlined="true"
                          Class="pa-4 flex-grow-1"
                          Style="overflow-y:auto;">
                    <MudText>@((MarkupString)HtmlText)</MudText>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</AdminLayout>