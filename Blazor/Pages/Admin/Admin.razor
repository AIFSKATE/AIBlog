@page "/admin"

<AdminLayout>
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-4">
        <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-8 fw-bold">
            - 博客内容管理 -
        </MudText>

        <MudGrid Justify="Justify.Center" Spacing="4">
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 text-center py-8 mud-theme-primary">
                    <MudIcon Icon="@Icons.Material.Filled.EditNote" Size="Size.Large" Class="mb-2" />
                    <MudLink Href="/admin/post" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="d-block stretched-link">新增文章</MudLink>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 text-center py-8">
                    <MudIcon Icon="@Icons.Material.Filled.LibraryBooks" Size="Size.Large" Color="Color.Primary" Class="mb-2" />
                    <MudLink Href="/posts" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="d-block stretched-link">文章管理</MudLink>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 text-center py-8">
                    <MudIcon Icon="@Icons.Material.Filled.Category" Size="Size.Large" Color="Color.Secondary" Class="mb-2" />
                    <MudLink Href="/admin/categories" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="d-block stretched-link">分类管理</MudLink>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 text-center py-8">
                    <MudIcon Icon="@Icons.Material.Filled.LocalOffer" Size="Size.Large" Color="Color.Info" Class="mb-2" />
                    <MudLink Href="/tags" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="d-block stretched-link">标签管理</MudLink>
                </MudPaper>
            </MudItem>
            <MudItem xs="12" sm="6" md="4">
                <MudPaper Elevation="2" Class="pa-6 text-center py-8">
                    <MudIcon Icon="@Icons.Material.Filled.Link" Size="Size.Large" Color="Color.Success" Class="mb-2" />
                    <MudLink Href="/admin/friendlinks" Typo="Typo.h6" Color="Color.Inherit" Underline="Underline.None" Class="d-block stretched-link">友链管理</MudLink>
                </MudPaper>
            </MudItem>
        </MudGrid>
    </MudContainer>
</AdminLayout>