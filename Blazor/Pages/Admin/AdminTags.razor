@page "/admin/tags"
@using Mapper.DTO

<AdminLayout>
    <MudContainer MaxWidth="MaxWidth.Large" Class="mt-8 mb-4">
        <div class="d-flex align-center mb-6">
            <MudText Typo="Typo.h6" Class="fw-bold">标签管理</MudText>
            <MudText Typo="Typo.body2" Class="ms-4 mud-text-secondary">共 @(tags?.Count ?? 0) 个</MudText>
            <MudSpacer />
            <MudButton Variant="Variant.Outlined"
                       StartIcon="@Icons.Material.Outlined.Add"
                       OnClick="AddTag">
                新增标签
            </MudButton>
        </div>

        @if (tags == null)
        {
            <div class="d-flex justify-center my-16">
                <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
            </div>
        }
        else
        {
            <div class="d-flex flex-wrap gap-2">
                @foreach (var tag in tags)
                {
                    @* 增加 tag-chip-hover 类名 *@
                    <MudChip T="TagDTO"
                             Variant="Variant.Outlined"
                             OnClose="@(() => OpenDeleteDialog(tag))"
                             CloseIcon="@Icons.Material.Outlined.Close"
                             Class="tag-chip-hover pa-4">
                        <div class="d-flex align-center">
                            <MudLink Href="@($"/tag/{tag.Id}")"
                                     Target="_blank"
                                     Underline="Underline.None"
                                     Color="Color.Default"
                                     Class="mr-2"
                                     Style="font-weight: 500;">
                                @tag.TagName
                            </MudLink>

                            <MudIconButton Icon="@Icons.Material.Outlined.Edit"
                                           Size="Size.Small"
                                           OnClick="@(() => UpdateTag(tag))"
                                           Class="pa-0"
                                           Style="font-size: 1.1rem;" />
                        </div>
                    </MudChip>
                }
            </div>
        }
    </MudContainer>
</AdminLayout>

<style>
    .tag-chip-hover:hover {
        border-color: var(--mud-palette-primary);
        background-color: var(--mud-palette-background-grey);
    }
</style>