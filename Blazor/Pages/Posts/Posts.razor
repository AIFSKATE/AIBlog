@page "/posts/"
@page "/posts/page/{page:int}"
@page "/posts/{page:int}"

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-4">
    @if (PostData == null)
    {
        <div class="d-flex justify-center my-16">
            <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
        </div>
    }
    else if (!PostData.Posts.Any())
    {
        <div class="d-flex justify-center my-8">
            <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">暂无文章</MudAlert>
        </div>
    }
    else
    {
        <MudStack Spacing="0">
            @foreach (var item in PostData.Posts)
            {
                <div class="d-flex justify-space-between align-center py-4 mud-border-bottom">
                    <MudLink Href="@($"/post/{item.Id}")" Typo="Typo.h6" Underline="Underline.Hover" Color="Color.Default">
                        @item.Title
                    </MudLink>
                    <MudText>
                        @item.CreationTime
                    </MudText>
                </div>
                <MudDivider />
            }
        </MudStack>

        @if (TotalPage > 1)
        {
            <div class="d-flex justify-center mt-8">
                <MudPagination Count="@TotalPage"
                               Selected="@(page ?? 1)"
                               SelectedChanged="OnPageChanged"
                               ShowFirstButton="true"
                               Variant="Variant.Outlined"
                               ShowLastButton="true" />
            </div>
        }
    }
</MudContainer>