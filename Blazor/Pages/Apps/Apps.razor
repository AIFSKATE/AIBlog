@page "/apps"

<MudContainer MaxWidth="MaxWidth.Medium" Class="mt-8 mb-4">
    <MudText Typo="Typo.h4" Align="Align.Center" Class="mb-8 fw-bold">
        - Apps -
    </MudText>

    @* 使用 MudStack 实现垂直间距 *@
    <MudStack Spacing="4">
        <MudPaper Class="pa-4" Elevation="1">
            <MudLink Href="https://www.bilibili.com/" Target="_blank" Typo="Typo.h6" Underline="Underline.Hover" Color="Color.Primary">
                我最爱的霹雳霹雳
            </MudLink>
        </MudPaper>

        <MudPaper Class="pa-4" Elevation="1">
            <MudLink Href="/friendlinks" Typo="Typo.h6" Underline="Underline.Hover" Color="Color.Primary">
                友情链接
            </MudLink>
        </MudPaper>
    </MudStack>
</MudContainer>