@* Header.razor *@
<MudAppBar Elevation="1" Color="Color.Surface">
    @* 左侧 Logo *@
    <MudLink Href="/" Underline="Underline.None" Color="Color.Inherit" Typo="Typo.h5" Class="fw-bold">
        AIBlog
    </MudLink>

    @* 占据中间可用空间，将后面的链接推到右边 *@
    <MudSpacer />

    @* 右侧导航链接，添加了一些左右边距 (mx-3) 保持间距 *@
    <MudLink Href="posts" Underline="Underline.Hover" Color="Color.Inherit" Class="mx-3">Posts</MudLink>
    <MudLink Href="categories" Underline="Underline.Hover" Color="Color.Inherit" Class="mx-3">Categories</MudLink>
    <MudLink Href="tags" Underline="Underline.Hover" Color="Color.Inherit" Class="mx-3">Tags</MudLink>
    <MudLink Href="apps" Underline="Underline.Hover" Color="Color.Inherit" Class="mx-3">Apps</MudLink>
</MudAppBar>