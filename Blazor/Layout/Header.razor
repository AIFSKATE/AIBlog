    <MudLink Href="posts" Underline="Underline.Hover" Typo="Typo.body1" Color="Color.Default" Class="mx-4">Posts</MudLink>
    <MudLink Href="categories" Underline="Underline.Hover" Typo="Typo.body1" Color="Color.Default" Class="mx-4">Categories</MudLink>
    <MudLink Href="tags" Underline="Underline.Hover" Typo="Typo.body1" Color="Color.Default" Class="mx-4">Tags</MudLink>
    <MudLink Href="apps" Underline="Underline.Hover" Typo="Typo.body1" Color="Color.Default" Class="mx-4">Apps</MudLink>
