        <div class="footer-links">
            <a class="footer-link" href="/" title="Home">Home</a>
            <a class="footer-link" href="/posts" title="Posts">Posts</a>
            <a class="footer-link" href="https://github.com/AIFSKATE/AIBlog" target="_blank" title="GitHub">GitHub</a>
