<!-- Footer.razor -->
@using MudBlazor

<MudPaper Class="footer" Elevation="0">
    <div class="footer-content">
        <div class="footer-tech-stack">
            <span class="footer-tech-item">
                <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" />
                .NET 8
            </span>
            <span class="footer-tech-item">
                <MudIcon Icon="@Icons.Material.Filled.Web" Size="Size.Small" />
